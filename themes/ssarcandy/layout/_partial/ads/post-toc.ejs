<% if (theme.adsense.enable) { %>
    <% if (theme.adsense.in_slot && theme.adsense.in_slot.post_toc) { %>
        <div class="ads-post-toc">
            <!-- Fixed 200x600 skyscraper, per the AdSense unit spec. The TOC gutter
                 is always >=225px when the widget shows, so the fixed width fits; -->
            <ins class="adsbygoogle"
                style="display:inline-block;width:200px;height:600px"
                data-ad-client="<%- theme.adsense.client %>"
                data-ad-slot="<%- theme.adsense.in_slot.post_toc %>"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </div>
    <% } %>
<% } %>