<% var shareUrl = encodeURIComponent(config.url + url_for(path)); %>
<% var shareText = encodeURIComponent(page.title || config.title); %>
<div class="<%= className %>" id="<%= className %>">
    <p class="share-title">Share</p>
    <ul class="reset share-icons">
      <li>
        <a class="share-sns share-facebook" target="_blank" rel="noopener noreferrer" data-title="Facebook" aria-label="Share on Facebook"
           href="https://www.facebook.com/sharer/sharer.php?u=<%= shareUrl %>">
          <span class="share-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"/></svg>
          </span>
          <span class="share-label">Facebook</span>
        </a>
      </li>
      <li>
        <a class="share-sns share-x" target="_blank" rel="noopener noreferrer" data-title="X" aria-label="Share on X"
           href="https://x.com/intent/tweet?url=<%= shareUrl %>&text=<%= shareText %>">
          <span class="share-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </span>
          <span class="share-label">X</span>
        </a>
      </li>
      <li>
        <a class="share-sns share-direct" href="#" data-title="Direct Share" aria-label="Direct share"
           onclick="event.preventDefault(); if (navigator.share) { navigator.share({ title: document.title, url: location.href }).catch(function () {}); } else if (navigator.clipboard) { navigator.clipboard.writeText(location.href); }">
          <span class="share-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
          </span>
          <span class="share-label">Direct Share</span>
        </a>
      </li>
    </ul>
 </div>
