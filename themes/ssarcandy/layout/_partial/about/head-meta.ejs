<div class="brand-wrap">
  <div class="brand">
    <div class="about-img-container">
      <img src="/img/logo.png" alt="ssarcandy" class="about-head-photo">
    </div>
    <hgroup class="about-introduce">
      <div class="about-name">Andy Hsu</div>
      <!-- <div class="about-nickname"><%= theme.email %></div> -->
      <% if (theme.motto) { %><div class="about-motto"><%= theme.motto %></div><% } %>
    </hgroup>
    <hgroup class="about-sociallink">
      <%
      for (var i in theme.social_links) {
        icon = theme.social_links[i];
        var label = icon.name || i;
      %>
      <a class="about-social-icon" title="<%- label %>" aria-label="<%- label %>" href="<%- icon.url %>" target="<%- icon.target %>" rel="noopener">
        <%- partial('_partial/icon', { name: icon.icon, cls: 'icon-lg' }) %>
      </a>
      <%}%>
    </hgroup>
  </div>
</div>
