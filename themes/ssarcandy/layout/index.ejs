<%
    // Interleave a native in-feed ad after every N posts, only when an In-feed
    // unit (slot + layout_key) is configured. 0 disables interleaving.
    var __pad = theme.adsense && theme.adsense.enable && theme.adsense.in_feed && theme.adsense.in_feed.post_list;
    var __every = (__pad && __pad.slot && __pad.layout_key) ? (__pad.every || 4) : 0;
%>
<div class="post-list">
  <% page.posts.each(function(post, i) { %>
    <div class="post-list-item">
        <%- partial('_partial/index-item', {
            post: post,
            index: true
        }) %>
    </div>
    <% if (__every && (i + 1) % __every === 0) { %>
        <%- partial('_partial/ads/in-feed-post-list') %>
    <% } %>
  <% }) %>
</div>
<% if (page.total > 1) { %>
<nav id="page-nav">
    <div class="inner">
    <%- paginator({
        prev_text: __('page.prev'),
        next_text: __('page.next')
    }) %>
    </div>
</nav>
<% } %>