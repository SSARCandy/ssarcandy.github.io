<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js"></script>

<div class="photography-container">
    <div class="photography-toolbar">
        <div class="view-group" id="view-group" style="display: none;">
            <button class="view-btn active" data-view="grid" aria-label="Grid View"><i class="icon icon-th"></i></button>
            <button class="view-btn" data-view="map" aria-label="Map View"><i class="icon icon-map-marker"></i></button>
        </div>
        <div class="sort-group" id="sort-group">
            <button class="sort-btn" data-sort="date">Date</button>
            <button class="sort-btn" data-sort="views" id="sort-views-btn" style="display: none;">Views</button>
            <button class="sort-btn active" data-sort="random">Random</button>
        </div>
    </div>
    <div id="photography-grid" class="photography-grid">
        <div class="grid-sizer"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
    </div>
    <div id="photography-map" style="display: none; height: 600px; width: 100%; border-radius: 4px; overflow: hidden; margin-bottom: 20px;"></div>
</div>

<style>
.skeleton {
    height: 300px;
    background: #eee;
    background: linear-gradient(110deg, #ececec 8%, #f5f5f5 18%, #ececec 33%);
    background-size: 200% 100%;
    animation: 1.5s shine linear infinite;
    opacity: 1 !important;
}
@keyframes shine {
    to { background-position-x: -200%; }
}
.photography-container {
    padding: 0;
    max-width: 1200px;
    margin: 0 auto;
}
@media (max-width: 760px) {
    .photography-container {
        padding: 0 16px;
    }
}
.photography-toolbar {
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
}
.view-group {
    display: flex;
    gap: 8px;
}
.view-btn {
    background: #f5f5f5;
    border: 1px solid #ddd;
    padding: 0;
    width: 36px;
    height: 32px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 4px;
    cursor: pointer;
    color: #444;
    transition: all 0.2s ease;
}
.view-btn.active {
    background: #673AB7;
    color: #fff;
    border-color: #673AB7;
}
.sort-group {
    display: flex;
    align-items: center;
    gap: 8px;
}
.sort-label {
    font-size: 13px;
    color: #727272;
}
.sort-btn {
    background: #f5f5f5;
    border: 1px solid #ddd;
    padding: 0 12px;
    height: 32px;
    font-size: 12px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #444;
    display: flex;
    justify-content: center;
    align-items: center;
}
.sort-btn:hover, .view-btn:hover {
    background: #eeeeee;
}
.sort-btn.active {
    background: #673AB7;
    color: #fff;
    border-color: #673AB7;
}
.photography-grid {
    margin: 0 auto;
    width: 100%;
}
.grid-sizer, .grid-item {
    width: calc(50% - 8px);
}
.grid-item {
    margin-bottom: 16px;
    float: left;
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    opacity: 0;
    transition: opacity 0.4s ease-in, transform 0.3s ease;
}
.grid-item.revealed {
    opacity: 1;
}
.grid-item img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.3s ease;
}
.grid-item:hover img {
    transform: scale(1.05);
}
.photo-title {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 20px 12px 10px;
    color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
    pointer-events: none;
    opacity: 0.9;
    transition: opacity 0.3s ease;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
}
.grid-item:hover .photo-title {
    opacity: 1;
}
.photo-name {
    font-size: 13px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-right: 8px;
}
.photo-views {
    font-size: 11px;
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
}
#photography-map {
    display: none; 
    height: 600px; 
    width: 100%; 
    border-radius: 4px; 
    overflow: hidden; 
    margin-bottom: 20px;
    border: 1px solid #ddd;
}
@media (max-width: 600px) {
    #photography-map {
        height: 450px;
    }
}
.leaflet-container {
    background: #fff !important;
}
.map-marker-icon {
    border: 2px solid #673AB7;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(103, 58, 183, 0.3);
    overflow: hidden;
    background: white;
}
.map-marker-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.marker-cluster-small, .marker-cluster-medium, .marker-cluster-large {
    background-color: rgba(103, 58, 183, 0.4) !important;
}
.marker-cluster-small div, .marker-cluster-medium div, .marker-cluster-large div {
    background-color: #673AB7 !important;
    color: white !important;
}
@media (max-width: 760px) {
    .grid-sizer, .grid-item { width: 100% !important; }
}
</style>

<script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js"></script>
<script src="https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js"></script>

<script>
(function() {
    const USER_ID = '<%= theme.social_links.flickr.user_id %>';
    const API_KEY = '<%= theme.social_links.flickr.api_key %>';
    const container = document.querySelector('#photography-grid');
    const mapContainer = document.querySelector('#photography-map');
    
    let masterPhotos = []; // Keep original order
    let currentIsRestApi = false;
    let currentSort = 'random'; // 'date', 'views', or 'random'
    let masonryInstance = null;
    let mapInstance = null;
    let markersLayer = null;

    function initMap() {
        if (mapInstance) return;
        mapInstance = L.map('photography-map', {
            scrollWheelZoom: false, // Prevent scroll trapping
            tap: true,              // Ensure tap works well on mobile
            touchZoom: 'center',
            attributionControl: false
        }).setView([23.5, 121], 7); // Default to Taiwan
        
        mapInstance.on('focus', () => mapInstance.scrollWheelZoom.enable());
        mapInstance.on('blur', () => mapInstance.scrollWheelZoom.disable());

        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 20
        }).addTo(mapInstance);

        markersLayer = L.markerClusterGroup({
            showCoverageOnHover: false,
            maxClusterRadius: 30
        }).addTo(mapInstance);
    }

    function updateMarkers(photos) {
        if (!markersLayer) return;
        markersLayer.clearLayers();
        const bounds = [];
        
        photos.forEach(item => {
            if (item.latitude && item.longitude && parseFloat(item.latitude) !== 0) {
                const lat = parseFloat(item.latitude);
                const lng = parseFloat(item.longitude);
                const imgUrl = `https://live.staticflickr.com/${item.server}/${item.id}_${item.secret}_q.jpg`;
                const link = `https://www.flickr.com/photos/${item.owner}/${item.id}`;
                
                const customIcon = L.divIcon({
                    className: 'map-marker-icon',
                    html: `<img src="${imgUrl}" alt="${item.title}" loading="lazy">`,
                    iconSize: [70, 70],
                    iconAnchor: [30, 30]
                });

                const marker = L.marker([lat, lng], { icon: customIcon });
                marker.bindPopup(`
                    <div style="text-align:center; display:flex; flex-direction:column; align-items:center; width:150px;">
                        <a href="${link}" target="_blank" style="display:block; width:150px; height:150px; margin-bottom:8px;">
                            <img src="${imgUrl}" style="width:150px;height:150px;object-fit:cover;display:block;border-radius:2px;" loading="lazy">
                        </a>
                        <a href="${link}" target="_blank" style="text-decoration:none; color:#673AB7; font-size:12px; font-weight:500; display:block; text-align:center; word-wrap:break-word; white-space:normal;">
                            ${item.title}
                        </a>
                    </div>
                `);
                markersLayer.addLayer(marker);
                bounds.push([lat, lng]);
            }
        });
        
        if (bounds.length > 0) {
            mapInstance.fitBounds(bounds, { padding: [50, 50] });
        }
    }

    function sortPhotos(photos, type) {
        let sorted = [...photos];
        if (type === 'views') {
            sorted.sort((a, b) => (parseInt(b.views) || 0) - (parseInt(a.views) || 0));
        } else if (type === 'random') {
            for (let i = sorted.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [sorted[i], sorted[j]] = [sorted[j], sorted[i]];
            }
        } else {
            // Default: newest first (restore from master list order)
            return [...masterPhotos];
        }
        return sorted;
    }

    function renderPhotos(photos, isRestApi, isInitialLoad = false) {
        if (isInitialLoad) {
            masterPhotos = [...photos];
        }
        const sortedPhotos = sortPhotos(masterPhotos, currentSort);
        currentIsRestApi = isRestApi;
        
        container.innerHTML = '<div class="grid-sizer"></div>';
        if (masonryInstance) {
            masonryInstance.destroy();
            masonryInstance = null;
        }

        const fragment = document.createDocumentFragment();
        const newItems = [];
        
        sortedPhotos.forEach(item => {
            const div = document.createElement('div');
            div.className = 'grid-item';
            
            let imgUrl, link, title, views;
            if (isRestApi) {
                imgUrl = `https://live.staticflickr.com/${item.server}/${item.id}_${item.secret}_c.jpg`;
                link = `https://www.flickr.com/photos/${item.owner}/${item.id}`;
                title = item.title;
                views = item.views;
            } else {
                imgUrl = item.media.m.replace('_m.jpg', '_c.jpg');
                link = item.link;
                title = item.title;
                views = null;
            }

            const viewsHtml = views ? `<span class="photo-views"><i class="icon icon-eye"></i> ${views}</span>` : '';
            div.innerHTML = `
                <a href="${link}" target="_blank">
                    <img src="${imgUrl}" alt="${title}">
                    <div class="photo-title">
                        <span class="photo-name">${title}</span>
                        ${viewsHtml}
                    </div>
                </a>
            `;
            fragment.appendChild(div);
            newItems.push(div);
        });
        
        container.appendChild(fragment);
        
        imagesLoaded(container, function() {
            masonryInstance = new Masonry(container, {
                itemSelector: '.grid-item',
                columnWidth: '.grid-sizer',
                percentPosition: true,
                gutter: 16,
                transitionDuration: 0
            });
            
            requestAnimationFrame(() => {
                newItems.forEach(item => item.classList.add('revealed'));
            });
        });

        if (isRestApi) {
            document.querySelector('#view-group').style.display = 'flex';
            document.querySelector('#sort-views-btn').style.display = 'flex';
            updateMarkers(masterPhotos);
        }
    }

    // View toggle event listeners
    document.querySelectorAll('.view-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            if (this.classList.contains('active')) return;
            document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            const view = this.dataset.view;
            if (view === 'grid') {
                container.style.display = 'block';
                mapContainer.style.display = 'none';
                document.querySelector('#sort-group').style.display = 'flex';
                if (masonryInstance) masonryInstance.layout();
            } else {
                container.style.display = 'none';
                mapContainer.style.display = 'block';
                document.querySelector('#sort-group').style.display = 'none';
                initMap();
                updateMarkers(masterPhotos);
                setTimeout(() => {
                    if (mapInstance) mapInstance.invalidateSize();
                }, 100);
            }
        });
    });

    // Sort event listeners
    document.querySelectorAll('.sort-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            if (this.classList.contains('active')) return;
            document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            currentSort = this.dataset.sort;
            if (masterPhotos.length > 0) {
                renderPhotos(masterPhotos, currentIsRestApi);
            }
        });
    });

    // Fallback: Feed API
    window.jsonFlickrFeed = function(data) {
        console.log('Flickr: Using Feed API Fallback');
        renderPhotos(data.items, false, true);
    };

    // Primary: REST API
    window.jsonFlickrApi = function(data) {
        if (data.stat === 'ok') {
            renderPhotos(data.photos.photo, true, true);
        } else {
            console.error('Flickr REST API failed:', data.message);
            loadFeedApi();
        }
    };

    function loadFeedApi() {
        const script = document.createElement('script');
        script.src = `https://www.flickr.com/services/feeds/photos_public.gne?id=${USER_ID}&format=json`;
        document.head.appendChild(script);
    }

    function loadRestApi() {
        const script = document.createElement('script');
        script.src = `https://www.flickr.com/services/rest/?method=flickr.people.getPhotos&api_key=${API_KEY}&user_id=${USER_ID}&per_page=100&extras=views,geo&format=json&jsoncallback=jsonFlickrApi`;
        script.onerror = loadFeedApi;
        document.head.appendChild(script);
    }

    loadRestApi();

    window.addEventListener('resize', () => {
        if (masonryInstance) masonryInstance.layout();
    });
})();
</script>
