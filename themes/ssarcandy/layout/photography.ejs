<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
<script src="https://unpkg.com/supercluster@8.0.1/dist/supercluster.min.js"></script>

<link rel="preconnect" href="https://live.staticflickr.com" crossorigin>
<link rel="dns-prefetch" href="https://live.staticflickr.com">

<div class="photography-container">
    <div class="photography-toolbar">
        <div class="view-group">
            <button class="view-btn waves-effect active" data-view="grid" aria-label="Grid View"><i class="icon icon-th-large"></i></button>
            <button class="view-btn waves-effect" data-view="map" aria-label="Map View"><i class="icon icon-map-marker"></i></button>
        </div>
        <div class="sort-group" id="sort-group">
            <button class="sort-btn waves-effect active" data-sort="random">Random</button>
            <button class="sort-btn waves-effect" data-sort="date">Latest</button>
            <button class="sort-btn waves-effect" data-sort="views">Popular</button>
        </div>
    </div>
    <%
    // Photo metadata is captured at build time (helper/fetch_flickr_photos.js) and
    // read here so the grid is rendered as static HTML: content is in the page on
    // first paint, with no client fetch, no skeleton, and no JS-built DOM.
    var __photos = flickr_photos();

    // Flickr's natural order is newest-first, i.e. the "Latest" sort. Remember each
    // photo's natural position so Photography.js can restore that order by simply
    // reordering the rendered cards — no data needed on the client.
    var __naturalIndex = {};
    __photos.forEach(function(photo, i) { __naturalIndex[photo.id] = i; });

    // The default sort is "Random", so shuffle a copy of the order at build time —
    // the first paint already matches the active button. (The Random button
    // reshuffles live for repeat visits.) public/ is gitignored, so a per-build
    // shuffle produces no diff churn.
    var __display = __photos.slice();
    for (var i = __display.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = __display[i]; __display[i] = __display[j]; __display[j] = tmp;
    }

    // Native in-feed ad cadence (same config the projects/archive feeds use). 0
    // disables ads; data-ad-every lets the client re-interleave on re-sort.
    var __inFeed = theme.adsense && theme.adsense.enable && theme.adsense.in_feed && theme.adsense.in_feed.photography;
    var __adEvery = (__inFeed && __inFeed.slot && __inFeed.layout_key) ? (__inFeed.every || 8) : 0;
    %>
    <div id="photography-grid" class="photography-grid"<% if (__adEvery) { %> data-ad-every="<%= __adEvery %>"<% } %>>
        <div class="grid-sizer"></div>
        <% __display.forEach(function(item, i) { %>
            <%- partial('_partial/photography-item', { item: item, index: __naturalIndex[item.id], priority: i < 4 }) %>
            <% if (__adEvery && (i + 1) % __adEvery === 0) { %>
                <%- partial('_partial/ads/in-feed-photography') %>
            <% } %>
        <% }); %>
    </div>
    <div id="photography-map" style="display: none;"></div>
</div>

<script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js"></script>
<script src="https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js"></script>
<script src="<%- url_for('js/photography.bundle.js') %>" type="module"></script>
