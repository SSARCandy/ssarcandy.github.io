<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js"></script>
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
<script src="https://unpkg.com/@maplibre/maplibre-gl-leaflet@0.0.20/leaflet-maplibre-gl.js"></script>

<link rel="preconnect" href="https://live.staticflickr.com" crossorigin>
<link rel="dns-prefetch" href="https://live.staticflickr.com">

<div class="photography-container">
    <div class="photography-toolbar">
        <div class="view-group" id="view-group" style="display: none;">
            <button class="view-btn waves-effect active" data-view="grid" aria-label="Grid View"><i class="icon icon-th-large"></i></button>
            <button class="view-btn waves-effect" data-view="map" aria-label="Map View"><i class="icon icon-map-marker"></i></button>
        </div>
        <div class="sort-group" id="sort-group">
            <button class="sort-btn waves-effect active" data-sort="random">Random</button>
            <button class="sort-btn waves-effect" data-sort="date">Latest</button>
            <button class="sort-btn waves-effect" data-sort="views" id="sort-views-btn" style="display: none;">Popular</button>
        </div>
    </div>
    <div id="photography-grid" class="photography-grid"
        data-user-id="<%= theme.social_links.flickr.user_id %>"
        data-api-key="<%= flickr_api_key() %>">
        <div class="grid-sizer"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
        <div class="grid-item skeleton"></div>
    </div>
    <div id="photography-map" style="display: none; height: 600px; width: 100%; border-radius: 4px; overflow: hidden; margin-bottom: 20px;"></div>
</div>

<script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js"></script>
<script src="https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js"></script>
<%- js('js/photography.bundle.js') %>
