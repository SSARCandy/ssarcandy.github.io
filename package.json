{
  "name": "ssarcandy-blog",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "hexo server -s",
    "build": "npm-run-all build:*",
    "build:flickr": "node ./helper/fetch_flickr_photos.js",
    "build:pageview": "node ./helper/ga_pageview.js > pageview.json",
    "build:vite": "vite build",
    "build:hexo": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "lint": "./node_modules/.bin/eslint themes/ssarcandy/js",
    "dev": "npm-run-all --parallel watch:assets dev:hexo",
    "dev:hexo": "hexo server --debug",
    "watch:assets": "vite build --watch"
  },
  "hexo": {
    "version": "7.3.0"
  },
  "dependencies": {
    "@google-analytics/data": "^6.1.0",
    "hexo": "^7.3.0",
    "hexo-clean-css": "^2.0.0",
    "hexo-cli": "^4.3.2",
    "hexo-filter-mathjax": "0.9.0",
    "hexo-generator-archive": "2.0.0",
    "hexo-generator-feed": "^4.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-json-content": "4.2.3",
    "hexo-generator-sitemap": "3.0.1",
    "hexo-generator-tag": "2.0.0",
    "hexo-html-minifier": "^1.0.0",
    "hexo-reading-time": "^1.0.3",
    "hexo-renderer-ejs": "2.0.0",
    "hexo-renderer-less": "4.0.0",
    "hexo-renderer-marked": "^7.0.1",
    "hexo-tag-photozoom": "^1.0.3",
    "image-size": "^2.0.2",
    "lunr": "^2.3.9",
    "node-waves": "^0.7.6"
  },
  "devDependencies": {
    "eslint": "^8.38.0",
    "hexo-browsersync": "^0.3.0",
    "hexo-deployer-git": "4.0.0",
    "hexo-server": "3.0.0",
    "npm-run-all": "^4.1.5",
    "vite": "^6.0.0"
  }
}
